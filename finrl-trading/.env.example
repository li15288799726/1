# FinRL-Integrated Environment Configuration
# ===========================================

# Application Settings
# --------------------
APP_NAME=FinRL-Integrated
VERSION=1.0.0
ENVIRONMENT=development

# Trading Configuration
# --------------------
# Default trading parameters
DEFAULT_INITIAL_CAPITAL=1000000
DEFAULT_BUY_COST_PCT=0.001
DEFAULT_SELL_COST_PCT=0.001
DEFAULT_GAMMA=0.99
DEFAULT_LOOKBACK=50

# Asset Configuration
# -------------------
# Default crypto tickers
DEFAULT_CRYPTO_TICKERS=BTCUSDT,ETHUSDT

# Default stock tickers  
DEFAULT_STOCK_TICKERS=AAPL,MSFT,GOOGL,AMZN,TSLA

# Asset type configuration
DEFAULT_ASSET_TYPE=both  # crypto | stock | both

# DRL Configuration
# ------------------
# Default DRL algorithm
DEFAULT_DRL_ALGORITHM=PPO

# Training parameters
DEFAULT_EPISODES=100
DEFAULT_NET_DIM=256
DEFAULT_LEARNING_RATE=0.0001

# Environment Parameters
# ----------------------
# Normalization factors
NORM_CASH=1e-6
NORM_STOCKS=100
NORM_TECH=1
NORM_REWARD=1
NORM_ACTION=1

# Data Configuration
# ------------------
# Data directories
DATA_BASE_DIR=./data
DATA_CRYPTO_DIR=./data/crypto
DATA_STOCK_DIR=./data/stock
DATA_CACHE_DIR=./data/cache
DATA_PROCESSED_DIR=./data/processed

# Cache settings
DATA_CACHE_TTL_HOURS=24
DATA_MAX_CACHE_SIZE_MB=1000

# Trading Hours
# -------------
# Crypto markets: 24/7
CRYPTO_MARKET_HOURS=24/7

# Stock market hours (US Eastern)
STOCK_MARKET_OPEN=09:30
STOCK_MARKET_CLOSE=16:00
STOCK_MARKET_TIMEZONE=US/Eastern

# Risk Management
# ---------------
# Risk limits
MAX_WEIGHT_PER_ASSET=0.1
MAX_PORTFOLIO_TURNOVER=0.5
MIN_ORDER_SIZE=0.0001  # For crypto
RISK_FREE_RATE=0.02

# Logging Configuration
# ----------------------
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_PATH=./logs/finrl_integrated.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# API Keys Configuration
# -----------------------
# Note: These should be set in your local .env file
# 
# Binance API (for crypto trading)
# API_KEY_BINANCE=your_binance_api_key_here
# API_SECRET_BINANCE=your_binance_secret_key_here
#
# Alpaca API (for stock trading)
# APCA_API_KEY=your_alpaca_api_key_here
# APCA_API_SECRET=your_alpaca_secret_key_here
# APCA_BASE_URL=https://paper-api.alpaca.markets
#
# FMP API (for financial data)
# FMP_API_KEY=your_fmp_api_key_here
#
# OpenAI API (for sentiment analysis)
# OPENAI_API_KEY=your_openai_api_key_here

# Development Settings
# --------------------
# Debug mode
DEBUG_MODE=false
VERBOSE_LOGGING=false

# Testing
ENABLE_TESTS=true
TEST_DATA_DIR=./tests/data

# Performance Settings
# --------------------
# GPU settings
CUDA_VISIBLE_DEVICES=0
USE_CUDA=true

# Parallel processing
NUM_WORKERS=4
BATCH_SIZE=32

# Model Settings
# --------------
# Model persistence
MODEL_SAVE_DIR=./models
MODEL_LOAD_DIR=./models
MODEL_BACKUP_DIR=./models/backups

# Training settings
TRAINING_CHECKPOINT_INTERVAL=10
TRAINING_EARLY_STOPPING_PATIENCE=20

# Backtesting Settings
# --------------------
# Backtest configuration
BACKTEST_START_DATE=2022-01-01
BACKTEST_END_DATE=2022-12-31
BACKTEST_INITIAL_CAPITAL=1000000

# Benchmark settings
BENCHMARK_TICKERS=SPY,QQQ
BENCHMARK_START_DATE=2022-01-01
BENCHMARK_END_DATE=2022-12-31

# Paper Trading Settings
# ----------------------
# Paper trading configuration
PAPER_TRADING_ACCOUNT=paper1
PAPER_TRADING_START_CAPITAL=100000
PAPER_TRADING_ENABLED=true

# Order execution
ORDER_TIMEOUT_SECONDS=30
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1

# Web Interface Settings
# ----------------------
# Streamlit web app (optional)
WEB_HOST=0.0.0.0
WEB_PORT=8501
WEB_DEBUG=false
WEB_THEME=light

# Security Settings
# -----------------
# API rate limiting
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=3600

# Data validation
ENABLE_DATA_VALIDATION=true
VALIDATION_THRESHOLD=0.95

# Backup Settings
# ---------------
# Automatic backup
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Backup directories
BACKUP_DIR=./backups
DATA_BACKUP_DIR=./backups/data
MODEL_BACKUP_DIR=./backups/models

# Monitoring and Alerting
# -----------------------
# Performance monitoring
ENABLE_MONITORING=true
MONITORING_INTERVAL_SECONDS=60

# Alert thresholds
DRAWDOWN_THRESHOLD=0.1
VOLATILITY_THRESHOLD=0.3
SHARPE_RATIO_THRESHOLD=1.0

# Notification settings
ENABLE_EMAIL_ALERTS=false
EMAIL_RECIPIENT=admin@example.com

# Integration Settings
# --------------------
# External integrations
ENABLE_CCXT_INTEGRATION=true
ENABLE_ALPACA_INTEGRATION=true
ENABLE_YAHOO_FINANCE_INTEGRATION=true
ENABLE_FMP_INTEGRATION=true

# Performance optimization
ENABLE_CACHING=true
ENABLE_PARALLEL_PROCESSING=true
ENABLE_GPU_ACCELERATION=true

# Feature flags
# -------------
# Enable/disable features
ENABLE_DRL_STRATEGIES=true
ENABLE_TECHNICAL_INDICATORS=true
ENABLE_SENTIMENT_ANALYSIS=false
ENABLE_PORTFOLIO_OPTIMIZATION=true
ENABLE_RISK_MANAGEMENT=true

# Documentation
# --------------
# Project documentation
DOCUMENTATION_DIR=./docs
API_DOCS_DIR=./docs/api
USER_GUIDE_DIR=./docs/user_guide
EXAMPLES_DIR=./examples

# Note: This file contains default configuration values.
# Create a .env file in your project root to override these values with your specific settings.
# Never commit your .env file to version control!